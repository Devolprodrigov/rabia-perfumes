{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A perfume product in the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the perfume" },
        "description": { "type": "string", "description": "Detailed description" },
        "price": { "type": "number", "description": "Price in BRL" },
        "category": { "type": "string", "description": "Category ID or name" },
        "stock": { "type": "number", "description": "Current stock level" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "imageUrl"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "items", "total", "status"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of perfumes"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of sales history"
    }
  }
}
